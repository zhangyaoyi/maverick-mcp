<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.maverick.tiingoloader.weekly</string>

    <key>WorkingDirectory</key>
    <string>/Users/overman/Workspace/maverick-mcp</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/overman/.local/bin</string>
    </dict>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/overman/.local/bin/uv</string>
        <string>run</string>
        <string>--env-file</string>
        <string>/Users/overman/Workspace/maverick-mcp/.env</string>
        <string>scripts/load_tiingo_data.py</string>
        <string>--sp500</string>
        <!-- 深度刷新：拉取2年完整数据并重算所有技术指标 -->
        <string>--years</string>
        <string>2</string>
        <string>--calculate-indicators</string>
        <string>--run-screening</string>
    </array>

    <!-- 每周六 北京时间 14:00 深度更新 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key><integer>6</integer>
        <key>Hour</key><integer>14</integer>
        <key>Minute</key><integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/overman/Workspace/maverick-mcp/logs/tiingo.weekly.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/overman/Workspace/maverick-mcp/logs/tiingo.weekly.err.log</string>
</dict>
</plist>
